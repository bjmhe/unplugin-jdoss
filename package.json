{
  "name": "unplugin-jdoss",
  "version": "1.0.7",
  "description": "A build plugin based on unplugin that automatically uploads files to JD OSS after build completion.",
  "keywords": [
    "esbuild",
    "farm",
    "rolldown",
    "rollup",
    "rspack",
    "unplugin",
    "vite",
    "webpack"
  ],
  "homepage": "https://github.com/bjmhe/unplugin-jdoss#readme",
  "bugs": {
    "url": "https://github.com/bjmhe/unplugin-jdoss/issues"
  },
  "license": "MIT",
  "author": "Benjamin He <hi@bjmhe.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjmhe/unplugin-jdoss.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*.d.ts",
        "./*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./api": "./dist/api.js",
    "./esbuild": "./dist/esbuild.js",
    "./farm": "./dist/farm.js",
    "./rolldown": "./dist/rolldown.js",
    "./rollup": "./dist/rollup.js",
    "./rspack": "./dist/rspack.js",
    "./vite": "./dist/vite.js",
    "./webpack": "./dist/webpack.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "release": "bumpp",
    "prerelease": "vp run build"
  },
  "dependencies": {
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@types/node": "^25.6.0",
    "bumpp": "^11.0.1",
    "publint": "^0.3.21",
    "tsdown": "^0.22.0",
    "tsdown-preset-sxzz": "^0.6.0",
    "tsnapi": "^0.3.3",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.22"
  },
  "peerDependencies": {
    "@jd/upload-oss-tools": "1.1.28"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.33.4"
}
